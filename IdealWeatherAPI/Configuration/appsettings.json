{
  "AllowedHosts": "*",
  "Application": {
    "Name": "IdealWeatherAPI",
    "Version": "1.0.0"
  },
  "APIs": {
    "GeocodingCensusService": {
      "BaseURI": "https://geocoding.geo.census.gov/geocoder/",
      "Format": "json",
      "Accept": "application/json",
      "UserAgent": "WeatherApp.TestOil.com"
    },
    "GovernmentWeatherService": {
      "BaseURI": "https://api.weather.gov/",
      "UserAgent": "WeatherApp.TestOil.com",
      "Accept": "application/geo+json"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.OpenTelemetry" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "Endpoint": "http://otel-collector:4317",
          "Protocol": "grpc",
          "ResourceAttributes": {
            "service.name": "IdealWeatherAPI",
            "service.version": "1.0.0"
          },
          "IncludeScopes": true,
          "ExportedFields": [ "Timestamp", "Level", "Message", "Exception", "Properties" ]
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "OpenTelemetry": {
    "Resource": {
      "service.name": "MyApi",
      "service.version": "1.0.0"
    },
    "Tracing": {
      "Enabled": true,
      "Exporter": {
        "Endpoint": "http://otel-collector:4317",
        "Protocol": "grpc"
      },
      "Sampler": {
        "Type": "parentbased_always_on"
      }
    },
    "Metrics": {
      "Enabled": true,
      "Exporter": {
        "Endpoint": "http://otel-collector:4317",
        "Protocol": "grpc"
      },
      "IntervalSeconds": 10
    },
    "Logs": {
      "Enabled": true,
      "Exporter": {
        "Endpoint": "http://otel-collector:4317",
        "Protocol": "grpc"
      }
    }
  }

}
